rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Users profile
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Schemes are readable by anyone, write allowed for seeding
    match /schemes/{schemeId} {
      allow read: if true;
      allow write: if true;
    }
    
    // savedSchemes owned by user
    match /savedSchemes/{docId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
    
    // applications owned by user
    match /applications/{appId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
    
    // documents owned by user
    match /documents/{docId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
    
    // familyMembers owned by user
    match /familyMembers/{memberId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
    
    // reminders owned by user
    match /reminders/{reminderId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
    
    // notifications owned by user
    match /notifications/{notId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
    
    // chat_history owned by user
    match /chat_history/{chatId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
  }
}
